{
  "title": "Nexus Turn Response",
  "type": "object",
  "required": ["decision", "summary", "actions", "continue"],
  "properties": {
    "decision": {"type": "string", "enum": ["THINK", "WRITE_FILE", "APPEND_FILE", "UPDATE_GOAL", "MARK_GOAL_COMPLETE", "MARK_GOAL_BLOCKED", "STOP_RUN"]},
    "summary": {"type": "string"},
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {"type": "string", "enum": ["WRITE_FILE", "APPEND_FILE", "UPDATE_GOAL", "MARK_GOAL_COMPLETE", "MARK_GOAL_BLOCKED", "STOP_RUN"]},
          "path": {"type": "string"},
          "content": {"type": "string"},
          "goal_id": {"type": "string"},
          "patch": {"type": "object"}
        }
      }
    },
    "goal_update": {"type": "object"},
    "requested_tools": {"type": "array", "items": {"type": "string"}},
    "continue": {"type": "boolean"}
  }
}
